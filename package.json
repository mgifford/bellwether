{
  "name": "bellwether-report",
  "version": "0.1.0",
  "description": "Bellwether: a local-first WSG evaluation report and evidence tool. Automation provides evidence, never conformance.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "repository": "github:mgifford/bellwether",
  "scripts": {
    "snapshot": "node scripts/snapshot.mjs",
    "snapshot:local": "node scripts/snapshot.mjs --local",
    "diff": "node scripts/diff-snapshots.mjs",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate-snapshots.mjs",
    "validate:report": "node scripts/validate-report.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  }
}
