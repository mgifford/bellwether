{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bellwether STAR techniques snapshot",
  "type": "object",
  "required": ["snapshot_date", "techniques"],
  "additionalProperties": false,
  "properties": {
    "snapshot_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "techniques": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "section", "title", "guideline_refs", "test_count"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "section": { "type": "integer", "minimum": 2, "maximum": 5 },
          "title": { "type": "string", "minLength": 1 },
          "level": { "type": ["string", "null"] },
          "guideline_refs": { "type": "array", "items": { "type": "string", "pattern": "^[2-5]\\.\\d+$" } },
          "test_count": { "type": "integer", "minimum": 0 },
          "tests": { "type": "array" },
          "test_suite": {}
        }
      }
    }
  }
}
