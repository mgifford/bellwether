{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bellwether.dev/schemas/finding.schema.json",
  "title": "Bellwether finding",
  "description": "A single WSG success-criterion evaluation result. testability_level and result_status are independent axes; every finding must carry both.",
  "type": "object",
  "required": [
    "id",
    "wsg_ref",
    "wsg_guideline",
    "wsg_title",
    "wsg_section",
    "testability_level",
    "result_status",
    "evaluation_method",
    "evidence",
    "affected_urls",
    "confidence",
    "sensitivity",
    "last_updated",
    "modified_after_import"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "wsg_ref": { "type": "string", "pattern": "^[2-5]\\.\\d+\\.\\d+$" },
    "wsg_guideline": { "type": "string", "pattern": "^[2-5]\\.\\d+$" },
    "wsg_title": { "type": "string", "minLength": 1 },
    "wsg_section": {
      "type": "string",
      "enum": ["ux-design", "web-development", "hosting-infrastructure", "business-product"]
    },
    "ppp": {
      "type": "array",
      "items": { "type": "string", "enum": ["planet", "people", "prosperity"] }
    },
    "testability_level": {
      "type": "string",
      "enum": [
        "automatically-tested",
        "partially-automated",
        "manual-review-required",
        "organizational-evidence-required",
        "not-evaluated",
        "not-applicable",
        "cannot-determine"
      ]
    },
    "result_status": {
      "type": "string",
      "enum": [
        "pass",
        "needs-improvement",
        "fail",
        "not-applicable",
        "not-tested",
        "cannot-determine",
        "requires-organizational-evidence"
      ]
    },
    "evaluation_method": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": { "$ref": "evidence.schema.json" }
    },
    "affected_urls": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "severity": {
      "type": ["string", "null"],
      "enum": ["critical", "serious", "moderate", "minor", "none", null]
    },
    "impact": { "type": ["string", "null"] },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "remediation_recommendation": { "type": ["string", "null"] },
    "owner": { "type": ["string", "null"] },
    "remediation_status": {
      "type": ["string", "null"],
      "enum": ["open", "planned", "in-progress", "resolved", "wont-fix", null]
    },
    "reviewer": { "type": ["string", "null"] },
    "review_date": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "notes": { "type": ["string", "null"] },
    "related_standards": { "type": "array", "items": { "type": "string" } },
    "related_issue_url": { "type": ["string", "null"] },
    "sensitivity": { "type": "string", "enum": ["public", "internal", "restricted"] },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" },
    "modified_after_import": { "type": "boolean" }
  },
  "if": {
    "properties": {
      "result_status": { "enum": ["not-tested", "not-applicable"] }
    },
    "required": ["result_status"]
  },
  "then": {},
  "else": {
    "properties": {
      "evidence": { "type": "array", "minItems": 1 }
    }
  }
}
