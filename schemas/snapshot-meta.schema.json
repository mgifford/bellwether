{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bellwether snapshot metadata",
  "type": "object",
  "required": ["snapshot_date", "upstream", "fetched_at", "tool_version", "counts"],
  "additionalProperties": false,
  "properties": {
    "snapshot_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "upstream": {
      "type": "object",
      "required": ["repository", "guidelines_last_modified"],
      "properties": {
        "repository": { "const": "w3c/sustainableweb-wsg" },
        "guidelines_last_modified": { "type": "string" },
        "star_last_modified": { "type": "string" },
        "impact_last_modified": { "type": "string" },
        "edition": { "type": "string" }
      }
    },
    "fetched_at": { "type": "string" },
    "tool_version": { "type": "string" },
    "counts": {
      "type": "object",
      "required": ["sections", "guidelines", "criteria", "star_techniques"],
      "properties": {
        "sections": { "type": "integer" },
        "guidelines": { "type": "integer" },
        "criteria": { "type": "integer" },
        "star_techniques": { "type": "integer" },
        "star_unlinked": { "type": "integer" },
        "impact_ratings": { "type": "integer" },
        "impact_unlinked": { "type": "integer" }
      }
    },
    "star_unlinked_techniques": { "type": "array", "items": { "type": "string" } },
    "impact_unlinked_urls": { "type": "array", "items": { "type": "string" } }
  }
}
