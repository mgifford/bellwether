{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bellwether WSG guidelines snapshot",
  "type": "object",
  "required": ["snapshot_date", "sections"],
  "additionalProperties": false,
  "properties": {
    "snapshot_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "sections": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["section", "name", "short_name", "guidelines"],
        "additionalProperties": false,
        "properties": {
          "section": { "type": "integer", "minimum": 2, "maximum": 5 },
          "name": { "type": "string", "minLength": 1 },
          "short_name": { "type": "string", "minLength": 1 },
          "guidelines": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "slug", "url", "title", "criteria"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[2-5]\\.\\d+$" },
                "slug": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "pattern": "^https://www\\.w3\\.org/" },
                "title": { "type": "string", "minLength": 1 },
                "subheading": { "type": ["string", "null"] },
                "tags": { "type": "array", "items": { "type": "string" } },
                "benefits": { "type": "array" },
                "criteria": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["id", "position", "title", "description", "content_hash"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string", "pattern": "^[2-5]\\.\\d+\\.\\d+$" },
                      "position": { "type": "integer", "minimum": 1 },
                      "title": { "type": "string", "minLength": 1 },
                      "description": { "type": "string", "minLength": 1 },
                      "resources": { "type": "array" },
                      "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
